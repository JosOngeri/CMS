{
  "name": "kmaincms-backend",
  "version": "1.0.0",
  "description": "Kiserian Main SDA Church Website - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:setup": "node scripts/setup-test-db.js",
    "test": "node scripts/setup-test-db.js && jest --config=tests/jest.config.js",
    "test:watch": "jest --config=tests/jest.config.js --watch",
    "test:coverage": "jest --config=tests/jest.config.js --coverage",
    "test:unit": "jest --config=tests/jest.config.js --testPathPattern=unit",
    "test:integration": "jest --config=tests/jest.config.js --testPathPattern=integration",
    "test:e2e": "jest --config=tests/jest.config.js --testPathPattern=e2e",
    "benchmark": "node performance_benchmark.js",
    "security-audit": "node security_audit.js",
    "lint": "eslint .",
    "monitor": "node ../monitoring/production-monitor.js",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "church",
    "cms",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.2.0",
    "hibp": "^15.2.1",
    "ipaddr.js": "^2.4.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "multer": "^2.2.0-lts.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.6.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.13.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "rate-limit-redis": "^5.0.0",
    "redis": "^6.1.0",
    "socket.io": "^4.8.1",
    "speakeasy": "^2.0.0",
    "telegram": "^2.26.22",
    "uuid": "^14.0.1",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  },
  "overrides": {
    "js-yaml": "^4.2.0",
    "rimraf": "^4.4.1",
    "glob": "^10.4.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(hibp)/)"
    ]
  }
}
