# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cms_db
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_TO_SECURE_DB_PASSWORD_MIN_24_CHARS

# Redis Cache
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=CHANGE_THIS_TO_SECURE_JWT_SECRET_MIN_32_CHARS_RANDOM_STRING
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=CHANGE_THIS_TO_SECURE_REFRESH_SECRET_MIN_32_CHARS_RANDOM_STRING
REFRESH_TOKEN_EXPIRES_IN=30d

# Frontend URLs
FRONTEND_URL=http://localhost:5180
FRONTEND_ORIGIN=http://localhost:5180
PRODUCTION_FRONTEND_URL=https://your-production-domain.com

# KopoKopo Payment Integration
KOPOKOPO_API_KEY=your_kopokopo_api_key
KOPOKOPO_API_SECRET=your_kopokopo_api_secret
KOPOKOPO_CALLBACK_URL=http://localhost:5000/api/payments/callback

# M-Pesa Integration (Phase 12)
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_PASSKEY=your_mpesa_passkey
MPESA_SHORTCODE=174379
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback

# SMS Integration (Phase 9)
SMS_API_URL=https://api.blessedtexts.com/sms
SMS_API_KEY=your_blessedtexts_api_key
SMS_SENDER_ID=KMainCMS

# SMS Providers (Phase 9)
JOSMS_API_KEY=your_josms_api_key
JOSMS_API_URL=http://localhost:3000/api
BLESSED_TEXTS_API_KEY=your_blessedtexts_api_key
BLESSED_TEXTS_API_URL=https://api.blessedtexts.com/v1
AFRICAS_TALKING_API_KEY=your_africas_talking_api_key
AFRICAS_TALKING_API_URL=https://api.africastalking.com/v1

# Telegram Integration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_SESSION_STRING=your_telegram_session_string

# Google Gemini AI (Phase 13)
GEMINI_API_KEY=your_gemini_api_key

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@kmaincms.com

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.jpg,.jpeg,.png

# Session Management
SESSION_SECRET=CHANGE_THIS_TO_SECURE_SESSION_SECRET_MIN_32_CHARS_RANDOM_STRING
SESSION_MAX_AGE=86400000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
BCRYPT_ROUNDS=12
MFA_ISSUER=kmaincms
MFA_SECRET_LENGTH=32

# Multi-Tenancy (Phase 6)
DEFAULT_CHURCH_SLUG=kiserian-main-sda
CHURCH_DOMAIN=kmaincms.org

# Monitoring
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
ENABLE_ERROR_LOGGING=true
