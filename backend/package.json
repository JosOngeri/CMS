{
  "name": "kmaincms-backend",
  "version": "1.0.0",
  "description": "Kiserian Main SDA Church Website - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --config=tests/jest.config.js",
    "test:watch": "jest --config=tests/jest.config.js --watch",
    "test:coverage": "jest --config=tests/jest.config.js --coverage",
    "test:unit": "jest --config=tests/jest.config.js --testPathPattern=unit",
    "test:integration": "jest --config=tests/jest.config.js --testPathPattern=integration",
    "test:e2e": "jest --config=tests/jest.config.js --testPathPattern=e2e",
    "benchmark": "node performance_benchmark.js",
    "security-audit": "node security_audit.js",
    "lint": "eslint .",
    "monitor": "node ../monitoring/production-monitor.js",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "church",
    "cms",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "hibp": "^15.2.1",
    "jsonwebtoken": "^9.0.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "multer": "^2.2.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.11.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "pino-pretty": "^11.0.0",
    "pino-roll": "^2.0.0",
    "redis": "^4.6.0",
    "socket.io": "^4.7.2",
    "speakeasy": "^2.0.0",
    "telegram": "^2.26.22",
    "uuid": "^14.0.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^30.4.2",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.4"
  },
  "overrides": {
    "js-yaml": "^4.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(hibp)/)"
    ]
  }
}
